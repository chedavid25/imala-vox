rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función central de seguridad para SuperAdmin
    function isSuperAdmin() {
      let configPath = /databases/$(database)/documents/plataforma/config;
      return request.auth != null && 
             exists(configPath) && 
             request.auth.uid in get(configPath).data.superAdminUids;
    }

    // Configuración global: Se permite lectura a todos los autenticados
    match /plataforma/config {
      allow read: if request.auth != null;
      allow write: if false; 
    }
    
    // Reglas para Espacios de Trabajo y todo su contenido
    match /espaciosDeTrabajo/{wsId} {
      allow read, write: if isSuperAdmin() || (
        request.auth != null && 
        (resource == null || resource.data.propietarioUid == request.auth.uid)
      );
      
      match /{allPaths=**} {
        allow read, write: if isSuperAdmin() || (
          request.auth != null && 
          get(/databases/$(database)/documents/espaciosDeTrabajo/$(wsId)).data.propietarioUid == request.auth.uid
        );
      }

      match /canales/{canalId}/secrets/{secretId} {
        allow read, write: if false;
      }
    }

    // Reglas para consultas globales (Collection Groups)
    match /{path=**}/eventosFact/{event} {
      allow read: if isSuperAdmin();
    }
    
    // IMPORTANTE: Permitir lectura a usuarios autenticados para que puedan 
    // listar archivos y ver su uso en el dashboard
    match /{path=**}/baseConocimiento/{recurso} {
      allow read: if request.auth != null; 
    }
    
    match /{path=**}/conocimientoActivo/{activa} {
      allow read: if request.auth != null;
    }

    // Prevención por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
