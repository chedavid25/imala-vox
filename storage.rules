rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Archivos de workspace: solo el propietario autenticado puede leer/escribir
    // Ruta: espaciosDeTrabajo/{wsId}/recursos/{archivo}
    match /espaciosDeTrabajo/{wsId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Ruta utilizada por la aplicación para archivos de chat/media (lectura pública para que clientes y WhatsApp puedan acceder)
    match /workspaces/{wsId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Denegar todo lo demás por defecto
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
